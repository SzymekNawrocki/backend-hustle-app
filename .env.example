# =============================================================================
# .env.example — szablon zmiennych środowiskowych.
# Skopiuj do .env i uzupełnij wartości. Nigdy nie commituj .env do repozytorium.
#
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Baza danych
# -----------------------------------------------------------------------------

# Produkcja (Supabase) — skopiuj z: Supabase → Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Lokalny docker-compose — docker-compose.yml nadpisuje tę wartość automatycznie,
# ale wypełnij żeby `alembic` działał poza dockerem (np. z venv):
DATABASE_URL=postgresql://hustle:hustle@localhost:5433/hustle

# SSL: true dla Supabase/produkcji, false dla lokalnego PostgreSQL
DB_SSL=false

# -----------------------------------------------------------------------------
# Bezpieczeństwo
# -----------------------------------------------------------------------------

# Minimum 32 znaki. Wygeneruj: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------

# Klucz API do Groq (llama-3.3-70b-versatile)
# Wygeneruj na: https://console.groq.com/keys
GROQ_API_KEY=gsk_CHANGE_ME

# -----------------------------------------------------------------------------
# Auth cookie
# -----------------------------------------------------------------------------

AUTH_COOKIE_NAME=token

# false dla localhost (http), true dla produkcji (https + cross-site)
AUTH_COOKIE_SECURE=false

# lax dla localhost, none dla cross-site (Vercel frontend + Render backend)
AUTH_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# CORS — lista dozwolonych origins jako JSON array
# -----------------------------------------------------------------------------

# Lokalny development:
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Produkcja (dodaj swój URL Vercel):
# BACKEND_CORS_ORIGINS=["https://hustle-app-theta.vercel.app","http://localhost:3000"]
